{
    "devices": [
        {
            "data_type": "SECONDS",
            "device_type": "SAMPLE",
            "key": "RUN_TIME",
            "title": "Run Time"
        }
        ,
        {
            "device_type": "GPIO",
            "pins": [
                {
                    "BCM": 24,
                    "data_type": "BOOL",
                    "gpio.mode": "input",
                    "key": "POWER_FAIL",
                    "title": "AC Power Fail Bit",
                    "gpio.flags": 512
                }
            ]
        }

    ],
    "values": [
        {
            "data_type": "INT",
            "description": "A counter bumped each startup",
            "initial.value": 0,
            "key": "START_COUNT",
            "title": "times restarted running",
            "tracking": "track.latest"
        }
    ],
    "sequence": [
        {
            "enable": true,
            "name": "other startup task",
            "description": "fool with device on startup",
            "trigger": {
                "event": "startup"
            },
            "steps": {
                "action": [
                    {
                        "cmd": "EVAL",
                        "expression": "START_COUNT := START_COUNT + 1"
                    }
                ]
            }
        }
    ]
}
